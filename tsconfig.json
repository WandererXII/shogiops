{
  "compilerOptions": {
    "strict": true,
    "strictPropertyInitialization": false,
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "types": ["node"],
    "target": "ES2017",
    "lib": ["ES2017"],
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "outDir": "dist",
    "declarationDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedDeclarations": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", "test", "scripts"]
}
